# Qwen Cloud — OpenAI-compatible endpoint via Alibaba Cloud Model Studio (DashScope)
# Get your key + free hackathon credits at https://www.qwencloud.com/challenge/hackathon/voucher-application
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Supabase — service role key, same pattern FreshDrop already uses to bypass RLS
# in the notification system. NEVER expose this key client-side.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Payments — reuse whichever of these FreshDrop already has configured
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxx

# Human-in-the-loop guardrail. Refund amounts above this (in your currency's
# smallest unit, e.g. kobo for NGN) force escalation instead of auto-resolve.
AUTO_RESOLVE_REFUND_THRESHOLD=500000

# Shared secret the Supabase Edge Function sends in a header so randoms
# on the internet can't trigger your agent
WEBHOOK_SHARED_SECRET=change-me-to-something-long-and-random

PORT=8080
